.cube-swipe
  overflow: hidden

.cube-swipe-item-wrapper
  overflow: hidden

.cube-swipe-item
  position: relative
  overflow: hidden
  background: #fff

.cube-swipe-item-scroller
  position: relative
  z-index: 2
  background: #fff
  transform: translate3d(0, 0, 0)

.cube-swipe-item-inner
  min-height: 60px
  padding: 0 20px
  display: flex
  align-items: center
  font-size: 16px
  line-height: 22px
  box-sizing: border-box
  border-bottom-width: 1px
  border-bottom-style: solid
  border-bottom-color: #ebedf0

.cube-swipe-btns
  position: absolute
  right: 0
  top: 0
  bottom: 0
  z-index: 1
  display: flex
  align-items: stretch
  justify-content: flex-end

.cube-swipe-btn
  height: 100%
  display: flex
  align-items: center
  justify-content: center

.cube-swipe-btn-text
  color: #fff
  font-size: 15px
  padding: 0 12px
