@require "../../common/stylus/variable.styl"

.cube-sticky
  position: relative
  height: 100%
  overflow: hidden

.cube-sticky-fixed
  z-index: 1
  position: absolute
  left: 0
  right: 0

.cube-sticky-fixed_hide
  opacity: 0

.cube-sticky-fixed_show
  opacity: 1

